# Polymarket Market Maker Configuration
# Copy this file to .env and fill in your credentials

# Required: Your wallet private key (without 0x prefix)
POLY_PRIVATE_KEY=0x1e6ea4e5b1322be87601a115e9206f1bfd1f06cef076e6de1c1a9b2f22b0fa06

# Optional: Pre-saved L2 API credentials for faster startup
# If not set, credentials will be derived from private key on each startup
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
