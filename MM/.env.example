# Polymarket Market Maker Configuration
# Copy this file to .env and fill in your credentials

# Required: Your wallet private key. Never commit a real key.
POLY_PRIVATE_KEY=0xREPLACE_WITH_PRIVATE_KEY

# Optional: proxy/funder address that holds the Polymarket funds.
POLY_PROXY_ADDRESS=

# Optional: Pre-saved L2 API credentials for faster startup
# If not set, credentials will be derived from private key on each startup
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
